@host = http://localhost:8009
@username = GY24428
@password = ddd2025


### ─── 登录获取 Token ───
# @name login
POST {{host}}/api/v1/auth/login
Content-Type: application/json

{
  "username": "{{username}}",
  "password": "{{password}}"
}


### 列出用户（管理员）
# @name admin_users
GET {{host}}/api/v1/admin/users?search=
Authorization: Bearer {{login.response.body.access_token}}


### ─── 聊天 ───

### 第一轮：打招呼
POST {{host}}/api/v1/chat
Content-Type: application/json
Authorization: Bearer {{login.response.body.access_token}}

{
  "session_id": "1001",
  "message": "用 ls 列出 /uploads/{{username}}/1001/ 里的文件"
}


### 第二轮：追问（多轮对话，同一个 session_id）
POST {{host}}/api/v1/chat
Content-Type: application/json
Authorization: Bearer {{login.response.body.access_token}}

{
  "session_id": "1001",
  "message": "刚才列出的文件里，找一个toml文件打开看看",
  "model_override": {
    "model_name": "Qwen3.6-35B-A3B",
    "base_url": "http://172.16.66.13:8003/v1",
    "api_key": "75ddc7233ab54209b6b850e02bd5925e"
  }
}


### PLC 代码审查
POST {{host}}/api/v1/chat
Content-Type: application/json
Authorization: Bearer {{login.response.body.access_token}}

{
  "session_id": "1001",
  "message": "根据PLC代码审查skill在当前workspace输出分析报告，并把用户的偏好'使用中文交流'写入 memories 目录"
}


### 创建天气 Skill
POST {{host}}/api/v1/chat
Content-Type: application/json
Authorization: Bearer {{login.response.body.access_token}}

{
  "session_id": "create-weather-skill",
  "message": "编写一个查下某个城市当天天气的skill，方便后续复用"
}


### 查询天气
POST {{host}}/api/v1/chat
Content-Type: application/json
Authorization: Bearer {{login.response.body.access_token}}

{
  "session_id": "create-weather-skill",
  "message": "查下下深圳今天的天气"
}


