#!/usr/bin/env python3
# -*- coding: utf-8 -*-
"""
PLC代码审查工具 - 气缸专用�?功能�?1. 读取PLC XML源码，解析所有变量（支持数组下标如SFJ_KDJC[0]�?2. 只读取Excel�?气缸"Sheet，进行变量比�?3. 检查变量命名规范（模块前缀�?4. 生成带时间戳的审查报告（避免覆盖�?5. 输出清理后的PLC源码（去注释、去空行�?
使用方法�?    python plc_audit.py <plc_xml_file> <excel_file1> [excel_file2 ...] [output_dir]

参数�?    plc_xml_file: PLC源码XML文件路径（必需�?    excel_files: 一个或多个Excel IO数据库文件路径（必需�?    output_dir: 输出目录（可选，�?o�?-output指定，默认为当前目录�?
示例�?    python plc_audit.py code.xml io_table.xlsx
    python plc_audit.py code.xml io_table.xlsx io_database.xlsx
    python plc_audit.py code.xml io_table.xlsx io_database.xlsx -o ./reports
"""

import xml.etree.ElementTree as ET
import pandas as pd
import re
import sys
import os
import json
from datetime import datetime
from collections import defaultdict


def parse_plc_variables(plc_file):
    """
    解析PLC文件（支持XML或JSON Lines格式），提取变量�?    返回: list of dict {name, type, line, context}
    """
    # 首先尝试检测文件格�?    with open(plc_file, 'rb') as f:
        raw_content = f.read()
    
    # 去除BOM
    if raw_content.startswith(b'\xef\xbb\xbf'):
        raw_content = raw_content[3:]
    
    # 检测文件格�?    content_str = raw_content.decode('utf-8', errors='ignore').strip()
    
    # 检查是否为JSON格式（以 { 开头）
    if content_str.startswith('{'):
        return parse_plc_json(plc_file, raw_content)
    else:
        return parse_plc_xml(plc_file, raw_content)


def parse_plc_json(plc_file, raw_content):
    """
    解析JSON Lines格式的PLC文件
    """
    variables = []
    line_num = 0
    
    content_str = raw_content.decode('utf-8', errors='ignore')
    
    for line in content_str.split('\n'):
        line_num += 1
        line = line.strip()
        if not line:
            continue
        
        try:
            data = json.loads(line)
            
            # 从CLs中提取TXT字段
            if 'CLs' in data and isinstance(data['CLs'], list):
                for cl in data['CLs']:
                    if 'TXT' in cl and cl['TXT']:
                        txt = cl['TXT']
                        
                        # 提取整行注释（行�?/后的内容，遇到换行停止）
                        line_comment = ""
                        if '//' in txt:
                            parts = txt.split('//')
                            if len(parts) > 1:
                                # 只取//后的内容，遇到换行符(\r或\n)就停�?                                comment_part = parts[1]
                                # 找到第一个换行符的位�?                                newline_pos = len(comment_part)
                                for i, char in enumerate(comment_part):
                                    if char in '\r\n':
                                        newline_pos = i
                                        break
                                line_comment = comment_part[:newline_pos].strip()
                        
                        # 提取函数调用中的IO参数（先执行，确保函数参数被正确标记�?                        # 匹配 FC_XXX(...)
                        function_pattern = r'(FC_\w+|FB_\w+|F_\w+)\s*\(([^)]*)\)'
                        functions = re.findall(function_pattern, txt)
                        
                        for func_name, func_params in functions:
                            # 在函数参数中查找IO地址
                            # 模式1: ParamName := IOAddress (输入参数，IO在右�?
                            # 模式2: ParamName => IOAddress (输出参数，IO在右�?
                            # 支持 NOT 前缀: Param := NOT IA0008
                            param_pattern = r'(\w+)\s*:=\s*(?:NOT\s+)?(IA\d+|ID\d+|OD\d+|OF\d+|I\d+|Q\d+|O\d+)|(\w+)\s*=>\s*(?:NOT\s+)?(IA\d+|ID\d+|OD\d+|OF\d+|I\d+|Q\d+|O\d+)'
                            param_matches = re.findall(param_pattern, func_params)
                            
                            for match in param_matches:
                                # match �?tuple，提取非空的参数名和IO地址
                                param_name = match[0] if match[0] else match[2]
                                io_addr = match[1] if match[1] else match[3]
                                if param_name and io_addr:
                                    # 检查是否已存在该变�?                                    existing = [v for v in variables if v.get('io_address') == io_addr and v.get('name') == param_name and v.get('function') == func_name]
                                    if not existing:
                                        variables.append({
                                            'name': param_name,
                                            'type': guess_type_from_io(io_addr),
                                            'line': line_num,
                                            'context': f"{func_name}({func_params[:50]}...)",
                                            'io_address': io_addr,
                                            'function': func_name,
                                            'is_function_param': True
                                            # 不设置comment字段 - 函数调用本身不是注释
                                        })
                        
                        # 提取普通变量赋值模�? VarName := IOAddress（排除已标记为函数参数的�?                        # 支持多种IO前缀: IA, ID, OD, OF, I, Q, O
                        # 支持 NOT 前缀: VarName := NOT IA0008
                        # 支持结构体成�? YTJ_QJ_SJ1.Sr_I := IA0000
                        assignments = re.findall(
                            r'([\w.]+)\s*:=\s*(?:NOT\s+)?(IA\d+|ID\d+|OD\d+|OF\d+|I\d+|Q\d+|O\d+)',
                            txt
                        )
                        
                        for var_name, io_addr in assignments:
                            if is_valid_variable(var_name):
                                # 检查是否已存在（避免重复添加函数参数）
                                existing = [v for v in variables if v.get('io_address') == io_addr and v.get('name') == var_name]
                                if not existing:
                                    variables.append({
                                        'name': var_name,
                                        'type': guess_type_from_io(io_addr),
                                        'line': line_num,
                                        'context': txt[:100],
                                        'io_address': io_addr,
                                        'comment': line_comment
                                    })
                        
                        # 也提取普通变量（没有IO赋值的�?                        var_pattern = r'\b([A-Za-z_][A-Za-z0-9_]*)\b'
                        all_vars = re.findall(var_pattern, txt)
                        for var_name in all_vars:
                            # 排除函数名（FC_*, FB_*, F_*�?                            if re.match(r'^(FC_|FB_|F_)', var_name):
                                continue
                            # 排除IO地址格式的名称（IA*, ID*, OD*, OF*�?                            if re.match(r'^(IA|ID|OD|OF)\d+$', var_name):
                                continue
                            # 排除单个字母I/O后跟数字（可能被误识别为IO地址�?                            if re.match(r'^[IOQ]\d+$', var_name):
                                continue
                            if is_valid_variable(var_name) and var_name not in [v['name'] for v in variables]:
                                variables.append({
                                    'name': var_name,
                                    'type': guess_type(var_name),
                                    'line': line_num,
                                    'context': txt[:100]
                                })
        except json.JSONDecodeError:
            pass
    
    return variables


def parse_plc_xml(plc_file, raw_content):
    """
    解析XML格式的PLC文件
    """
    root = ET.fromstring(raw_content)
    
    variables = []
    line_num = 0
    
    # 遍历所有元素查找变量定�?    for elem in root.iter():
        line_num += 1
        text = elem.text if elem.text else ""
        
        var_pattern = r'\b([A-Za-z_][A-Za-z0-9_]*(?:\[[0-9]+\])?)\b'
        
        if text:
            matches = re.findall(var_pattern, text)
            for match in matches:
                if is_valid_variable(match):
                    variables.append({
                        'name': match,
                        'type': guess_type(match),
                        'line': line_num,
                        'context': text[:100]
                    })
        
        for key, value in elem.attrib.items():
            matches = re.findall(var_pattern, str(value))
            for match in matches:
                if is_valid_variable(match):
                    variables.append({
                        'name': match,
                        'type': guess_type(match),
                        'line': line_num,
                        'context': f"{key}={value}"[:100]
                    })
    
    return variables


def is_valid_variable(name):
    """
    判断是否为有效的PLC变量�?    """
    # 排除常见关键字和数字
    keywords = {'IF', 'THEN', 'ELSE', 'END', 'AND', 'OR', 'NOT', 'TRUE', 'FALSE',
                'INT', 'BOOL', 'REAL', 'STRING', 'ARRAY', 'OF', 'VAR', 'VAR_INPUT',
                'VAR_OUTPUT', 'VAR_IN_OUT', 'VAR_GLOBAL', 'CONST', 'TYPE', 'STRUCT'}
    
    if name.upper() in keywords:
        return False
    
    # 排除纯数�?    if re.match(r'^[0-9]+$', name):
        return False
    
    # 排除过短的（可能是临时变量）
    if len(name) <= 1:
        return False
    
    return True


def guess_type(var_name):
    """
    根据变量名猜测类�?    """
    var_upper = var_name.upper()
    
    if var_upper.startswith('I'):
        return 'INPUT'
    elif var_upper.startswith('Q') or var_upper.startswith('O'):
        return 'OUTPUT'
    elif var_upper.startswith('M'):
        return 'MEMORY'
    elif 'FLAG' in var_upper:
        return 'BOOL'
    else:
        return 'UNKNOWN'


def guess_type_from_io(io_addr):
    """
    根据IO地址猜测类型
    """
    io_upper = io_addr.upper()
    
    if io_upper.startswith('IA'):
        return 'INPUT_ANALOG'
    elif io_upper.startswith('ID'):
        return 'INPUT_DIGITAL'
    elif io_upper.startswith('OD'):
        return 'OUTPUT_DIGITAL'
    elif io_upper.startswith('OF'):
        return 'OUTPUT_ANALOG'
    elif io_upper.startswith('I'):
        return 'INPUT'
    elif io_upper.startswith('Q') or io_upper.startswith('O'):
        return 'OUTPUT'
    else:
        return 'UNKNOWN'


def parse_excel_io_db(excel_files):
    """
    读取一个或多个Excel文件中的所有Sheet，解析IO数据�?    返回: dict {io地址: {变量�? 注释, sheet�? 文件名}} �?dict {变量�? {io地址, 注释, sheet�? 文件名}}
    """
    io_by_address = {}  # 通过IO地址索引
    io_by_name = {}     # 通过变量名索�?    
    # 确保是列�?    if isinstance(excel_files, str):
        excel_files = [excel_files]
    
    for excel_file in excel_files:
        if not os.path.exists(excel_file):
            print(f"[WARN] Excel文件不存�? {excel_file}")
            continue
            
        try:
            print(f"正在读取文件: {excel_file}")
            
            # 读取所有sheet�?            xl = pd.ExcelFile(excel_file)
            sheet_names = xl.sheet_names
            
            # 读取所有sheet
            for sheet_name in sheet_names:
                try:
                    df = pd.read_excel(excel_file, sheet_name=sheet_name)
                    
                    # 尝试找到各列
                    var_col = None
                    io_col = None
                    comment_col = None
                    hmi_col = None
                    
                    for col in df.columns:
                        col_str = str(col).upper()
                        # 变量名列
                        if any(kw in col_str for kw in ['变量', 'VAR', '名称', 'NAME', 'PLC']):
                            var_col = col
                        # IO地址�?                        elif any(kw in col_str for kw in ['IO', '地址', 'ADDR', 'DI01', 'HMI', 'HMI变量']):
                            if not io_col:
                                io_col = col
                            elif 'HMI' in col_str:
                                hmi_col = col
                        # 注释�?                        elif any(kw in col_str for kw in ['注释', 'COMMENT', '说明', 'DESC', 'CM']):
                            comment_col = col
                    
                    # 如果没找到，尝试根据数据内容推断
                    if io_col is None:
                        for col in df.columns:
                            # 查找包含IA/ID/OD/OF的列
                            sample = df[col].astype(str).head(10).tolist()
                            for s in sample:
                                if re.match(r'^(IA|ID|OD|OF)\d+$', str(s)):
                                    io_col = col
                                    break
                    
                    count = 0
                    # 解析每一�?                    for idx, row in df.iterrows():
                        var_names = []
                        io_addr = None
                        comment = ""
                        
                        # 获取IO地址
                        if io_col and pd.notna(row[io_col]):
                            io_val = str(row[io_col]).strip()
                            if re.match(r'^(IA|ID|OD|OF|I|Q)\d+$', io_val):
                                io_addr = io_val
                        
                        # 获取变量名（多个可能的列�?                        if var_col and pd.notna(row[var_col]):
                            var_val = str(row[var_col]).strip()
                            if var_val and var_val != 'nan':
                                var_names.append(var_val)
                        
                        # HMI列也可能有变量名
                        if hmi_col and pd.notna(row[hmi_col]):
                            hmi_val = str(row[hmi_col]).strip()
                            if hmi_val and hmi_val != 'nan' and hmi_val not in var_names:
                                var_names.append(hmi_val)
                        
                        # 获取注释
                        if comment_col and pd.notna(row[comment_col]):
                            comment = str(row[comment_col]).strip()
                        
                        # 存储映射关系
                        if io_addr:
                            io_by_address[io_addr] = {
                                'var_names': var_names,
                                'comment': comment,
                                'sheet': sheet_name,
                                'row': idx + 2,  # Excel行号�?开始，加上header�?                                'file': os.path.basename(excel_file)
                            }
                        
                        for var_name in var_names:
                            if var_name:
                                io_by_name[var_name] = {
                                    'io_address': io_addr or "",
                                    'comment': comment,
                                    'sheet': sheet_name,
                                    'file': os.path.basename(excel_file)
                                }
                            count += 1
                    
                    if count > 0:
                        print(f"  Sheet [{sheet_name}]: {count} 条记�?)
                        
                except Exception as e:
                    print(f"  读取Sheet {sheet_name} 出错: {e}")
            
        except Exception as e:
            print(f"读取Excel文件 {excel_file} 时出�? {e}")
    
    # 返回两个字典，方便不同方式查�?    return {'by_address': io_by_address, 'by_name': io_by_name}


def check_naming_conventions(var_name):
    """
    检查命名规范，返回问题描述和建�?    """
    issues = []
    
    # 检查模块前缀
    prefixes = ['JR_', 'XX_', 'QJ_', 'QD_', 'TJ_', 'MQ_', 'CJ_', 'ZJ_']
    
    # 提取基础变量名（去掉数组下标�?    base_name = re.sub(r'\[.*\]', '', var_name)
    
    has_prefix = any(base_name.startswith(prefix) for prefix in prefixes)
    
    if not has_prefix:
        # 尝试推断应该有什么前缀
        suggested_prefix = infer_prefix(var_name)
        if suggested_prefix:
            issues.append({
                'problem': '缺少模块前缀',
                'suggestion': f'建议改为 {suggested_prefix}{base_name}'
            })
        else:
            issues.append({
                'problem': '缺少模块前缀',
                'suggestion': f'建议添加模块前缀，如 JR_{base_name}'
            })
    
    return issues


def infer_prefix(var_name):
    """
    根据变量名推断模块前缀
    """
    var_upper = var_name.upper()
    
    # 入卷相关
    if any(kw in var_upper for kw in ['DUST', 'ROLL', 'JOIN', 'JR']):
        return 'JR_'
    # 下料相关
    elif any(kw in var_upper for kw in ['CUT', 'DISCHARGE', 'XX']):
        return 'XX_'
    # 气检相关
    elif any(kw in var_upper for kw in ['AIR', 'PRESSURE', 'CHECK', 'QJ']):
        return 'QJ_'
    # 切断相关
    elif any(kw in var_upper for kw in ['CUT', 'SEVER', 'QD']):
        return 'QD_'
    # 贴胶相关
    elif any(kw in var_upper for kw in ['TAPE', 'GLUE', 'TJ']):
        return 'TJ_'
    
    return None


def extract_device_base_name(comment):
    """
    从Excel注释中提取设备基础名（去掉回限/出限/报警等后缀�?    例如�?拐角贴胶缓存_拐角胶上切胶气缸回限' -> '拐角贴胶缓存_拐角胶上切胶气缸'
    """
    if not comment:
        return None
    
    # 需要移除的后缀列表
    suffixes = ['回限', '出限', '报警', '上限', '下限', '前限', '后限', '左限', '右限', 
                '上升�?, '下降�?, '伸出�?, '缩回�?, '原位', '到位', '原点',
                '前进', '后退', '左旋', '右旋', '正转', '反转']
    
    base_name = comment.strip()
    for suffix in suffixes:
        if base_name.endswith(suffix):
            base_name = base_name[:-len(suffix)]
            break
    
    return base_name if base_name != comment else None


def extract_var_prefix_suffix(var_name):
    """
    从PLC变量名中提取前缀和后缀
    例如�?YTJ_QJ_SJ1.Sr_I' -> ('YTJ_QJ_SJ1', 'Sr_I')
          'YTJ_QJ_SJ1' -> ('YTJ_QJ_SJ1', None)
    """
    if '.' in var_name:
        parts = var_name.split('.')
        return parts[0], parts[1]
    return var_name, None


def check_variable_device_match(var_name, excel_comment, io_address):
    """
    检查PLC变量名是否与Excel设备描述匹配
    返回: None表示匹配，或返回不匹配原因字符串
    
    匹配逻辑�?    1. 从Excel注释提取设备基础名（去掉回限/出限等后缀�?    2. 从PLC变量名提取前缀（去�?Sr_I/.Sr_O等后缀�?    3. 检查设备基础名和变量前缀的对应关�?    """
    # 提取设备基础�?    device_base = extract_device_base_name(excel_comment)
    if not device_base:
        return None  # 无法提取基础名，跳过检�?    
    # 提取变量前缀和后缀
    var_prefix, var_suffix = extract_var_prefix_suffix(var_name)
    
    # TODO: 这里需要建立设备基础名到变量前缀的映射表
    # 目前简化处理：只检查命名规范中的一致�?    # 如果变量名有结构体后缀(.Sr_I/.Sr_O/.Bn_On)，认为是有效的气缸变�?    valid_suffixes = ['Sr_I', 'Sr_O', 'Bn_On', 'Out', 'In']
    if var_suffix and var_suffix in valid_suffixes:
        return None  # 有有效的结构体后缀，认为匹�?    
    # 如果没有结构体后缀，检查是否在Excel中通过变量名匹�?    # 这种情况已经在前面处理过�?    return None


def generate_report(plc_vars, io_db, output_dir):
    """
    生成带时间戳的审查报�?    """
    timestamp = datetime.now().strftime('%Y%m%d_%H%M%S')
    report_file = os.path.join(output_dir, f'plc_audit_report_{timestamp}.md')
    
    io_by_name = io_db.get('by_name', {})
    io_by_address = io_db.get('by_address', {})
    
    # 统计
    total_vars = len(plc_vars)
    matched_by_name = 0
    matched_by_address = 0
    unmatched_vars = []
    naming_issues = []
    variable_mismatch_issues = []  # 重命名：变量名与设备描述不匹�?    
    for var in plc_vars:
        var_name = var['name']
        var_io = var.get('io_address', '')
        is_func_param = var.get('is_function_param', False)
        
        # 跳过函数参数（临时变量如st_0~st_15, UINT1等），这些不参与比对
        if is_func_param:
            continue
        
        # 检查变量名是否在Excel�?        if var_name in io_by_name:
            matched_by_name += 1
            excel_io = io_by_name[var_name].get('io_address', '')
            excel_comment = io_by_name[var_name].get('comment', '')
            # 检查变量名与设备描述是否匹配（�?节逻辑�?            mismatch = check_variable_device_match(var_name, excel_comment, excel_io)
            if mismatch:
                variable_mismatch_issues.append({
                    'var_name': var_name,
                    'code_io': var_io,
                    'excel_io': excel_io,
                    'excel_comment': excel_comment,
                    'reason': mismatch
                })
        # 检查IO地址是否在Excel中（反向查找�?        elif var_io and var_io in io_by_address:
            matched_by_address += 1
            excel_info = io_by_address[var_io]
            excel_comment = excel_info.get('comment', '')
            # 同样检查变量名与设备描述是否匹�?            mismatch = check_variable_device_match(var_name, excel_comment, var_io)
            if mismatch:
                variable_mismatch_issues.append({
                    'var_name': var_name,
                    'code_io': var_io,
                    'excel_io': var_io,
                    'excel_comment': excel_comment,
                    'reason': mismatch
                })
        else:
            unmatched_vars.append(var)
        
        # 检查命名规�?        issues = check_naming_conventions(var_name)
        if issues:
            for issue in issues:
                naming_issues.append({
                    'var_name': var_name,
                    'type': var['type'],
                    'io_address': var_io,
                    'problem': issue['problem'],
                    'suggestion': issue['suggestion']
                })
    
    # 生成Markdown报告
    with open(report_file, 'w', encoding='utf-8') as f:
        f.write('# PLC代码审查报告\n\n')
        f.write(f'生成时间: {datetime.now().strftime("%Y-%m-%d %H:%M:%S")}\n\n')
        
        # 统计摘要 - 表格形式
        f.write('## 统计摘要\n\n')
        f.write('| 统计�?| 数量 | 状�?|\n')
        f.write('|--------|------|------|\n')
        
        # IO地址统计
        plc_io_addresses = set(v.get('io_address', '') for v in plc_vars if v.get('io_address'))
        # io_by_address �?key 就是 IO 地址
        excel_io_addresses = set(io_by_address.keys())
        
        common_io = plc_io_addresses & excel_io_addresses
        only_in_excel = excel_io_addresses - plc_io_addresses
        only_in_plc = plc_io_addresses - excel_io_addresses
        
        f.write(f'| Excel中的IO地址 | {len(excel_io_addresses)} | - |\n')
        f.write(f'| PLC中的IO地址 | {len(plc_io_addresses)} | - |\n')
        f.write(f'| 共同地址 | {len(common_io)} | �?匹配 |\n')
        f.write(f'| 仅在Excel�?| {len(only_in_excel)} | ⚠️ 需核对 |\n')
        f.write(f'| 仅在PLC�?| {len(only_in_plc)} | ⚠️ 需核对 |\n')
        
        # 变量匹配统计
        f.write(f'| PLC变量总数 | {total_vars} | - |\n')
        f.write(f'| Excel匹配成功(按变量名) | {matched_by_name} | �?|\n')
        f.write(f'| Excel匹配成功(按IO地址) | {matched_by_address} | �?|\n')
        f.write(f'| Excel匹配失败 | {len(unmatched_vars)} | ⚠️ 需核对 |\n')
        f.write(f'| IO地址不匹�?| {len(variable_mismatch_issues)} | �?需修正 |\n')
        
        # 命名规范问题（去重后�?        seen_vars = set()
        unique_naming_count = 0
        for issue in naming_issues:
            if issue['var_name'] not in seen_vars:
                seen_vars.add(issue['var_name'])
                unique_naming_count += 1
        
        status_icon = '�?无问�? if unique_naming_count == 0 else '⚠️ 需修正'
        f.write(f'| 命名规范问题 | {unique_naming_count} | {status_icon} |\n')
        
        # 常见错误统计
        common_errors = len(variable_mismatch_issues)
        error_status = '�?无错�? if common_errors == 0 else '�?需修正'
        f.write(f'| 常见错误 | {common_errors} | {error_status} |\n\n')
        
        # 2. IO地址映射统计
        f.write('## 2. IO地址映射统计\n\n')
        
        # 2.1 地址分布
        f.write('### 2.1 地址分布\n\n')
        
        # Excel地址分类统计
        excel_ia = [a for a in excel_io_addresses if a.upper().startswith('IA')]
        excel_id = [a for a in excel_io_addresses if a.upper().startswith('ID')]
        excel_od = [a for a in excel_io_addresses if a.upper().startswith('OD')]
        excel_of = [a for a in excel_io_addresses if a.upper().startswith('OF')]
        excel_other = [a for a in excel_io_addresses if not any(a.upper().startswith(p) for p in ['IA', 'ID', 'OD', 'OF'])]
        
        f.write(f'**Excel IO�?({len(excel_io_addresses)}个地址)**\n')
        f.write(f'- 模拟输入地址 (IAxxx): {len(excel_ia)}个\n')
        f.write(f'- 数字输入地址 (IDxxx): {len(excel_id)}个\n')
        f.write(f'- 数字输出地址 (ODxxx): {len(excel_od)}个\n')
        f.write(f'- 模拟输出地址 (OFxxx): {len(excel_of)}个\n')
        if excel_other:
            f.write(f'- 其他地址: {len(excel_other)}个\n')
        f.write('\n')
        
        # PLC地址分类统计
        plc_ia = [a for a in plc_io_addresses if a.upper().startswith('IA')]
        plc_id = [a for a in plc_io_addresses if a.upper().startswith('ID')]
        plc_od = [a for a in plc_io_addresses if a.upper().startswith('OD')]
        plc_of = [a for a in plc_io_addresses if a.upper().startswith('OF')]
        plc_other = [a for a in plc_io_addresses if not any(a.upper().startswith(p) for p in ['IA', 'ID', 'OD', 'OF'])]
        
        f.write(f'**PLC源码 ({len(plc_io_addresses)}个地址)**\n')
        f.write(f'- 模拟输入地址 (IAxxx): {len(plc_ia)}个\n')
        f.write(f'- 数字输入地址 (IDxxx): {len(plc_id)}个\n')
        f.write(f'- 数字输出地址 (ODxxx): {len(plc_od)}个\n')
        f.write(f'- 模拟输出地址 (OFxxx): {len(plc_of)}个\n')
        if plc_other:
            f.write(f'- 其他地址: {len(plc_other)}个\n')
        f.write('\n')
        
        # 2.2 地址匹配情况
        f.write('### 2.2 地址匹配情况\n\n')
        f.write('| 类别 | 数量 | 说明 |\n')
        f.write('|------|------|------|\n')
        f.write(f'| 完全匹配 | {len(common_io)} | 地址在Excel和PLC中都有定�?|\n')
        f.write(f'| 仅在Excel�?| {len(only_in_excel)} | 可能是预留或未使用的IO |\n')
        f.write(f'| 仅在PLC�?| {len(only_in_plc)} | 可能是新增或Excel未记录的IO |\n\n')
        
        # 3. 仅在Excel中的地址
        if only_in_excel:
            f.write('## 3. 仅在Excel中的地址\n\n')
            f.write(f'**共{len(only_in_excel)}个地址**\n\n')
            f.write('| 地址 | Excel描述 | Sheet�?| 行号 | 来源文件 |\n')
            f.write('|------|-----------|---------|------|----------|\n')
            for addr in sorted(only_in_excel):  # 显示全部
                info = io_by_address.get(addr, {})
                comment = info.get('comment', '')
                sheet = info.get('sheet', '-')
                row = info.get('row', '-')
                source = info.get('file', '未知')
                f.write(f'| {addr} | {comment} | {sheet} | {row} | {source} |\n')
            f.write('\n')
        
        # 4. 仅在PLC中的地址
        if only_in_plc:
            f.write('## 4. 仅在PLC中的地址\n\n')
            f.write(f'**共{len(only_in_plc)}个地址**\n\n')
            f.write('| 地址 | PLC变量 | 函数�?| PLC注释 |\n')
            f.write('|------|---------|--------|---------|\n')
            # 查找这些地址对应的PLC变量
            plc_addr_to_var = {}
            for v in plc_vars:
                addr = v.get('io_address', '')
                if addr in only_in_plc:
                    if addr not in plc_addr_to_var:
                        plc_addr_to_var[addr] = []
                    plc_addr_to_var[addr].append(v)
            
            for addr in sorted(only_in_plc):  # 显示全部
                vars_list = plc_addr_to_var.get(addr, [])
                if vars_list:
                    # 去重：同一地址只保留一个条目，优先带函数名�?                    # 先按函数名排序（有函数名的在前）
                    vars_list.sort(key=lambda x: (not x.get('function', ''), x['name']))
                    
                    # 只取第一个（如果有函数名就是带函数名的，否则是普通变量）
                    v = vars_list[0]
                    var_name = v['name']
                    func_name = v.get('function', '')
                    comment = v.get('comment', '')
                    if not comment:
                        comment = '-'
                    f.write(f'| {addr} | `{var_name}` | {func_name} | {comment} |\n')
                else:
                    f.write(f'| {addr} | - | - | - |\n')
            f.write('\n')
            
            f.write('**分析**: 这些地址在PLC中有定义，但在Excel中未找到。可能原因：\n')
            f.write('1. 新增IO，Excel未更新\n')
            f.write('2. 辅助IO，未在Excel中记录\n')
            f.write('3. 传感�?按钮类IO\n\n')
        
        # 5. 地址映射示例 (匹配成功�?
        # 过滤掉只有函数参数的地址
        filtered_common_io = []
        for addr in common_io:
            # 查找PLC中对应此地址的非函数参数变量
            plc_vars_for_addr = [v for v in plc_vars if v.get('io_address') == addr and not v.get('is_function_param', False)]
            if plc_vars_for_addr:  # 只保留有实际变量的地址
                filtered_common_io.append(addr)
        
        if filtered_common_io:
            f.write('## 5. 地址映射示例\n\n')
            f.write(f'**共{len(filtered_common_io)}个匹配地址（已排除纯函数参数地址�?*\n\n')
            f.write('| 地址 | Excel描述 | PLC变量 | PLC注释 |\n')
            f.write('|------|-----------|---------|---------|\n')
            
            for addr in sorted(filtered_common_io):
                excel_info = io_by_address.get(addr, {})
                excel_comment = excel_info.get('comment', '')
                
                # 查找PLC中对应此地址的变量（过滤掉函数参数）
                plc_vars_for_addr = [v for v in plc_vars if v.get('io_address') == addr and not v.get('is_function_param', False)]
                
                for v in plc_vars_for_addr:
                    var_name = v['name']
                    plc_comment = v.get('comment', '')
                    if not plc_comment:
                        plc_comment = '-'
                    f.write(f'| {addr} | {excel_comment} | `{var_name}` | {plc_comment} |\n')
            f.write('\n')
        
        # 变量名与设备描述不匹配问题（第6节）
        if variable_mismatch_issues:
            f.write('## 6. 变量名与设备描述不匹配\n\n')
            f.write('匹配规则：设备基础名（去掉回限/出限/报警等后缀）应与变量前缀一致\n\n')
            f.write('| 序号 | PLC变量名 | IO地址 | Excel设备描述 | 不匹配原因 |\n')
            f.write('|------|-----------|--------|---------------|------------|\n')
            for idx, issue in enumerate(variable_mismatch_issues[:50], 1):  # 最多显示50个
                f.write(f'| {idx} | `{issue["var_name"]}` | {issue["code_io"]} | {issue["excel_comment"]} | {issue["reason"]} |\n')
            if len(variable_mismatch_issues) > 50:
                f.write(f'| ... | ... | ... | ... | 还有 {len(variable_mismatch_issues) - 50} 个 |\n')
            f.write('\n')
        
        # 未匹配的变量
        if unmatched_vars:
            f.write('## 7. Excel中未找到的变量\n\n')
            f.write('| 序号 | 变量�?| IO地址 | 类型 | 位置 |\n')
            f.write('|------|--------|--------|------|------|\n')
            for idx, var in enumerate(unmatched_vars[:100], 1):  # 最多显�?00�?                io_addr = var.get('io_address', '')
                f.write(f'| {idx} | `{var["name"]}` | {io_addr} | {var["type"]} | 第{var["line"]}�?|\n')
            if len(unmatched_vars) > 100:
                f.write(f'| ... | ... | ... | ... | 还有 {len(unmatched_vars) - 100} �?|\n')
            f.write('\n')
        
        # 命名规范问题 - 去重后显�?        if naming_issues:
            # 去重：按变量名去重，保留第一�?            seen_vars = set()
            unique_naming_issues = []
            for issue in naming_issues:
                var_name = issue['var_name']
                if var_name not in seen_vars:
                    seen_vars.add(var_name)
                    unique_naming_issues.append(issue)
            
            f.write('## 8. 命名规范问题\n\n')
            f.write(f'共发�?{len(unique_naming_issues)} 个唯一变量存在命名规范问题\n\n')
            f.write('| 序号 | 变量�?| IO地址 | 类型 | 问题 | 建议 |\n')
            f.write('|------|--------|--------|------|------|------|\n')
            for idx, issue in enumerate(unique_naming_issues, 1):
                f.write(f'| {idx} | `{issue["var_name"]}`. | {issue.get("io_address", "")} | {issue["type"]} | {issue["problem"]} | {issue["suggestion"]} |\n')
            f.write('\n')
        
        # 审核标准说明
        f.write('## 9. 审核标准\n\n')
        f.write('### 变量匹配规则\n')
        f.write('- 根据代码中的变量名或IO地址，在Excel中查找对应信息\n')
        f.write('- 按变量名查找: 代码变量�?vs Excel变量名\n')
        f.write('- 按IO地址查找: 代码IO地址 vs Excel IO地址\n')
        f.write('- 如果查不到，列出�?Excel中未找到的变�?\n\n')
        f.write('### IO地址不匹配检查\n')
        f.write('- 检查代码中的IO地址与Excel定义是否一致\n')
        f.write('- 示例: 代码�?`DustBoxCheck := IA2305` 但Excel�?IA2305 对应其他变量名\n\n')
        f.write('### 命名规范检查\n')
        f.write('- 变量名需要有正确的模块前缀\n')
        f.write('- 支持的前缀: JR_, XX_, QJ_, QD_, TJ_, MQ_, CJ_, ZJ_\n')
        f.write('- 示例: DustBoxCheck �?JR_DustBoxCheck\n\n')
    
    return report_file, timestamp


def clean_plc_source(plc_file, output_dir, timestamp):
    """
    清理PLC源码，解析JSON Lines格式，提取并输出干净的PLC代码
    - 去掉JSON包装和转义符
    - 删除�?// 注释行（�?/开头的行）
    - 保留行尾注释（用于Excel比对�?    - 保留纯PLC代码
    """
    output_file = os.path.join(output_dir, f'plc_source_cleaned_{timestamp}.txt')
    
    # 使用UTF-8带BOM读取
    with open(plc_file, 'r', encoding='utf-8-sig') as f:
        content_str = f.read()
    
    cleaned_lines = []
    
    for line in content_str.split('\n'):
        line = line.strip()
        if not line:
            continue
        
        try:
            data = json.loads(line)
            
            # 从CLs中提取TXT字段
            if 'CLs' in data and isinstance(data['CLs'], list):
                for cl in data['CLs']:
                    if 'TXT' in cl and cl['TXT']:
                        txt = cl['TXT']
                        # JSON解析已自动解�?\uXXXX 转义序列
                        # 分割多行
                        for code_line in txt.split('\r\n'):
                            code_line = code_line.strip()
                            if not code_line:
                                continue
                            # 跳过纯注释行（以//开头）
                            if code_line.startswith('//'):
                                continue
                            # 保留有代码的行（包括行尾注释�?                            cleaned_lines.append(code_line)
        except json.JSONDecodeError:
            # 如果不是JSON格式，处理原始行
            # 跳过纯注释行
            if line.startswith('//'):
                continue
            cleaned_lines.append(line)
    
    with open(output_file, 'w', encoding='utf-8') as f:
        f.write('\n'.join(cleaned_lines))
    
    return output_file


def main():
    # 解析参数
    if len(sys.argv) < 3:
        print("用法: python plc_audit.py <plc_xml_file> <excel_file1> [excel_file2 ...] [-o output_dir]")
        print("示例:")
        print("  python plc_audit.py code.xml io_table.xlsx")
        print("  python plc_audit.py code.xml io_table.xlsx io_database.xlsx")
        print("  python plc_audit.py code.xml io_table.xlsx io_database.xlsx -o ./reports")
        sys.exit(1)
    
    plc_file = sys.argv[1]
    
    # 收集excel文件和输出目�?    excel_files = []
    output_dir = '.'
    i = 2
    while i < len(sys.argv):
        arg = sys.argv[i]
        if arg in ['-o', '--output']:
            if i + 1 < len(sys.argv):
                output_dir = sys.argv[i + 1]
                i += 2
            else:
                print("错误: -o 参数需要指定输出目�?)
                sys.exit(1)
        elif arg.endswith('.xlsx') or arg.endswith('.xls'):
            excel_files.append(arg)
            i += 1
        else:
            # 假设是输出目录（旧版兼容�?            if i == len(sys.argv) - 1 and not arg.endswith('.xml'):
                output_dir = arg
            i += 1
    
    if not excel_files:
        print("错误: 至少需要指定一个Excel文件")
        sys.exit(1)
    
    # 检查文�?    if not os.path.exists(plc_file):
        print(f"错误: PLC文件不存�? {plc_file}")
        sys.exit(1)
    
    for excel_file in excel_files:
        if not os.path.exists(excel_file):
            print(f"错误: Excel文件不存�? {excel_file}")
            sys.exit(1)
    
    # 创建输出目录
    os.makedirs(output_dir, exist_ok=True)
    
    print("=" * 60)
    print("PLC代码审查工具 - 气缸专用�?)
    print("=" * 60)
    
    # 1. 解析PLC变量
    print(f"\n[1/4] 正在解析PLC文件: {plc_file}")
    plc_vars = parse_plc_variables(plc_file)
    print(f"      找到 {len(plc_vars)} 个变�?)
    
    # 2. 解析Excel（只读气缸Sheet�?    print(f"\n[2/4] 正在读取Excel文件（共{len(excel_files)}个）")
    for f in excel_files:
        print(f"      - {f}")
    io_db = parse_excel_io_db(excel_files)
    print(f"      IO数据库条目总数: {len(io_db.get('by_name', {}))} (按变量名) + {len(io_db.get('by_address', {}))} (按IO地址)")
    
    # 3. 生成报告
    print(f"\n[3/4] 正在生成审查报告...")
    report_file, timestamp = generate_report(plc_vars, io_db, output_dir)
    print(f"      报告已保�? {report_file}")
    
    # 4. 清理源码
    print(f"\n[4/4] 正在清理PLC源码...")
    cleaned_file = clean_plc_source(plc_file, output_dir, timestamp)
    print(f"      清理后源码已保存: {cleaned_file}")
    
    print("\n" + "=" * 60)
    print("审查完成!")
    print("=" * 60)
    print(f"\n输出文件:")
    print(f"  1. {report_file}")
    print(f"  2. {cleaned_file}")


if __name__ == '__main__':
    main()
